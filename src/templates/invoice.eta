<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #1a1a1a;
    margin: 0;
    padding: 40px;
    font-size: 13px;
    line-height: 1.5;
  }
  .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; }
  .brand { max-width: 60%; }
  .brand img { max-height: 56px; margin-bottom: 8px; }
  .brand h1 { font-size: 20px; margin: 0 0 4px; }
  .brand .meta { color: #666; white-space: pre-line; }
  .doc-title { text-align: right; }
  .doc-title h2 { font-size: 28px; letter-spacing: 2px; text-transform: uppercase; color: <%= it.accent %>; margin: 0 0 8px; }
  .doc-title .field { color: #666; }
  .doc-title .field b { color: #1a1a1a; }
  .parties { display: flex; gap: 40px; margin-bottom: 32px; }
  .parties .box { flex: 1; }
  .parties .label { text-transform: uppercase; font-size: 11px; letter-spacing: 1px; color: #999; margin-bottom: 4px; }
  .parties .name { font-weight: 600; }
  table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
  thead th {
    text-align: left; text-transform: uppercase; font-size: 11px; letter-spacing: 1px;
    color: #fff; background: <%= it.accent %>; padding: 10px 12px;
  }
  thead th.num, tbody td.num { text-align: right; }
  tbody td { padding: 10px 12px; border-bottom: 1px solid #eee; }
  .totals { width: 260px; margin-left: auto; }
  .totals .row { display: flex; justify-content: space-between; padding: 6px 0; }
  .totals .row.grand { border-top: 2px solid <%= it.accent %>; margin-top: 6px; padding-top: 10px; font-size: 16px; font-weight: 700; }
  .notes { margin-top: 40px; color: #666; white-space: pre-line; }
  .footer { margin-top: 48px; text-align: center; color: #aaa; font-size: 11px; }
</style>
</head>
<body>
  <div class="header">
    <div class="brand">
      <% if (it.company.logoUrl) { %><img src="<%= it.company.logoUrl %>" alt="logo"><% } %>
      <h1><%= it.company.name %></h1>
      <div class="meta"><%= it.company.address %></div>
      <% if (it.company.email) { %><div class="meta"><%= it.company.email %></div><% } %>
    </div>
    <div class="doc-title">
      <h2><%= it.title %></h2>
      <div class="field">No. <b><%= it.number %></b></div>
      <div class="field">Date: <b><%= it.date %></b></div>
      <% if (it.dueDate) { %><div class="field">Due: <b><%= it.dueDate %></b></div><% } %>
    </div>
  </div>

  <div class="parties">
    <div class="box">
      <div class="label">Bill To</div>
      <div class="name"><%= it.customer.name %></div>
      <% if (it.customer.address) { %><div class="meta"><%= it.customer.address %></div><% } %>
      <% if (it.customer.email) { %><div class="meta"><%= it.customer.email %></div><% } %>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Description</th>
        <th class="num">Qty</th>
        <th class="num">Unit Price</th>
        <th class="num">Amount</th>
      </tr>
    </thead>
    <tbody>
      <% it.items.forEach(function(item){ %>
      <tr>
        <td><%= item.description %></td>
        <td class="num"><%= item.quantity %></td>
        <td class="num"><%= it.fmt(item.unitPrice) %></td>
        <td class="num"><%= it.fmt(item.amount) %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="totals">
    <div class="row"><span>Subtotal</span><span><%= it.fmt(it.subtotal) %></span></div>
    <% if (it.taxAmount) { %><div class="row"><span>Tax (<%= it.taxRate %>%)</span><span><%= it.fmt(it.taxAmount) %></span></div><% } %>
    <% if (it.discount) { %><div class="row"><span>Discount</span><span>-<%= it.fmt(it.discount) %></span></div><% } %>
    <div class="row grand"><span>Total</span><span><%= it.currency %> <%= it.fmt(it.total) %></span></div>
  </div>

  <% if (it.notes) { %><div class="notes"><strong>Notes:</strong>
<%= it.notes %></div><% } %>

  <div class="footer">Generated by PDF Forge API</div>
</body>
</html>
