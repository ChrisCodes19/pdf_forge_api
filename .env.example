# Copy to .env for local dev. On Fly/Render set these in the dashboard.

# Port the server listens on (Render/Fly inject their own; default 3000 locally).
PORT=3000

# Shared secret that RapidAPI injects as the X-RapidAPI-Proxy-Secret header.
# In the RapidAPI dashboard: Security -> "Secret" / proxy secret. Paste the same
# value here so the API rejects any request that did NOT come through RapidAPI.
# Leave BLANK during local development to bypass the check (see server.js).
PROXY_SECRET=

# Max accepted request body size in bytes (default 2 MB). Guards memory on free tier.
MAX_BODY_BYTES=2097152

# Per-render hard timeout in milliseconds (default 20s).
RENDER_TIMEOUT_MS=20000
